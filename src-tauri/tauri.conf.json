{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zalo for Linux",
  "version": "0.1.4",
  "identifier": "vn.zalo.linuxwrapper",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zalo",
        "url": "https://chat.zalo.me/",
        "decorations": true,
        "width": 1200,
        "height": 800,
        "minWidth": 760,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "SocialNetworking",
    "shortDescription": "Zalo Web with Linux system tray",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
